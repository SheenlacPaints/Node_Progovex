{
    "name": "social-platform-backend",
    "version": "1.0.0",
    "description": "Social Platform Backend API",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "cross-env NODE_ENV=development nodemon",
        "dev:ts": "cross-env NODE_ENV=development ts-node src/server.ts",
        "build": "tsc",
        "clean": "cross-env rimraf dist",
        "rebuild": "npm run clean && npm run build",
        "build:watch": "tsc --watch",
        "worker:email": "cross-env NODE_ENV=production node dist/workers/emailWorker.js"
    },
    "keywords": [
        "social",
        "platform",
        "api",
        "express",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "bull": "^4.11.5",
        "compression": "^1.7.4",
        "cors": "^2.8.5",
        "crypto-js": "^4.1.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^6.10.0",
        "express-validator": "^7.0.1",
        "googleapis": "^171.4.0",
        "helmet": "^7.0.0",
        "imap": "^0.8.19",
        "jsonwebtoken": "^9.0.2",
        "mailparser": "^3.9.8",
        "microsoft-graph-client": "^1.0.43",
        "moment-timezone": "^0.6.2",
        "mongoose": "^7.5.0",
        "mssql": "^12.6.0",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.6.0",
        "nodemailer": "^6.9.4",
        "sharp": "^0.32.6",
        "socket.io": "^4.5.4",
        "winston": "^3.10.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.2",
        "@types/compression": "^1.7.2",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.2",
        "@types/mssql": "^12.3.0",
        "@types/multer": "^1.4.7",
        "@types/node": "^20.5.0",
        "@types/nodemailer": "^6.4.9",
        "@types/sharp": "^0.32.0",
        "cross-env": "^7.0.3",
        "nodemon": "^3.0.1",
        "rimraf": "^5.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.1.6"
    },
    "nodemonConfig": {
        "watch": [
            "src"
        ],
        "ext": "ts",
        "ignore": [
            "src/**/*.spec.ts"
        ],
        "exec": "cross-env NODE_ENV=development ts-node ./src/server.ts"
    }
}
